{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://suneung-viewer/config/human_review_results.schema.json",
  "title": "human_review_results",
  "description": "pat_decision_engine의 recommended 샘플에 대한 사람 검수 결과. 이 파일을 엔진이 loop back으로 읽어 signal_map/rules/override_cases를 튜닝한다.",
  "type": "object",
  "required": ["meta", "reviews"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["reviewer", "reviewed_at", "round_label", "report_snapshot"],
      "additionalProperties": false,
      "properties": {
        "reviewer": { "type": "string", "description": "검수자 식별 (예: 성진)" },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "round_label": { "type": "string", "description": "라운드 구분 (예: 2026-04-20-R1)" },
        "report_snapshot": {
          "type": "object",
          "required": ["exam", "report_generated_at"],
          "properties": {
            "exam": { "type": "string", "description": "검수 대상 연도키" },
            "report_generated_at": { "type": "string", "format": "date-time" },
            "rules_version": { "type": "string" },
            "signal_map_version": { "type": "string" },
            "override_version": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "choice_id",
          "exam",
          "category",
          "ok_issue_reason",
          "pat_issue_reason",
          "final_decision",
          "agreed_with_engine"
        ],
        "additionalProperties": false,
        "properties": {
          "choice_id": {
            "type": "string",
            "description": "예: 2026수능/l2026b/Q26/#2"
          },
          "exam": { "type": "string" },
          "set_id": { "type": ["string", "null"], "description": "템플릿 생성기가 원문에서 보강한 setId. 사람 입력 아님." },
          "question_id": { "type": ["string", "number", "null"], "description": "템플릿 생성기가 보강한 question id. 사람 입력 아님." },
          "choice_num": { "type": ["integer", "null"], "description": "템플릿 생성기가 보강한 choice 번호. 사람 입력 아님." },
          "domain": { "type": ["string", "null"], "description": "R|L|V|null — 템플릿 생성기가 보강. 사람 입력 아님." },
          "question_text": { "type": ["string", "null"], "description": "문항 발문 원문. 템플릿 생성기가 보강. 사람 입력 아님." },
          "bogi_text": { "type": ["string", "null"], "description": "<보기> 원문. 템플릿 생성기가 보강. 사람 입력 아님." },
          "choice_text": { "type": ["string", "null"], "description": "선지 원문. 템플릿 생성기가 보강. 사람 입력 아님." },
          "analysis_text": { "type": ["string", "null"], "description": "해설 원문. 템플릿 생성기가 보강. 사람 입력 아님." },
          "category": {
            "enum": [
              "mismatch_medium",
              "keep_existing_medium",
              "keep_existing_medium_2",
              "label_signal_disagree",
              "high_risk",
              "other"
            ]
          },
          "engine_snapshot": {
            "type": "object",
            "description": "엔진이 본 당시의 상태 스냅샷 (튜닝 추적용)",
            "additionalProperties": false,
            "properties": {
              "existing_pat": { "type": ["string", "null"] },
              "suggested_pat": { "type": ["string", "null"] },
              "match_type": { "type": "string" },
              "soft_conflict_risk_tier": { "type": ["string", "null"] },
              "ok_recheck_candidate_score": { "type": "number" },
              "applied_rule_id": { "type": "string" },
              "conflict_flags": { "type": "array", "items": { "type": "string" } },
              "primary_decision": { "type": "string" },
              "secondary_decision": { "type": ["string", "null"] },
              "decision_confidence": { "type": "number" },
              "ok_issue_reason_suggested": { "type": "string" },
              "pat_issue_reason_suggested": { "type": "string" }
            }
          },
          "ok_issue_reason": {
            "enum": [
              "axis_mismatch",
              "analysis_self_conflict",
              "polarity_conflict",
              "keep_existing_risk",
              "unclear",
              "none"
            ],
            "description": "해설·ok 축 이슈 분류. 'keep_existing_risk'는 fallback.keep_existing로 겉보기 match지만 해설 축이 실제와 어긋날 위험. 'none'은 ok 쪽엔 문제 없음."
          },
          "pat_issue_reason": {
            "enum": [
              "structure_vs_form",
              "cause_vs_fact",
              "concept_confusion",
              "theme_vs_expression",
              "unclear",
              "none"
            ],
            "description": "pat 축 이슈 분류. 'none'은 pat은 문제 없음."
          },
          "final_decision": {
            "enum": [
              "send_to_ok_recheck_queue",
              "send_to_pat_review_queue",
              "send_to_override_candidate_queue",
              "leave_as_is"
            ],
            "description": "사람 최종 결정. send_to_override_candidate_queue 는 pat 즉시 확정이 아니라 후보 큐에 올려 추가 검토 단계로 넘기는 것. human_pat_suggestion 동반 권장(필수는 아님)."
          },
          "human_pat_suggestion": {
            "type": ["string", "null"],
            "description": "사람이 제안하는 pat (R1~R4, L1~L5, V, null). send_to_override_candidate_queue에서 유효.",
            "pattern": "^(R[1-4]|L[1-5]|V|null)?$"
          },
          "human_ok_suggestion": {
            "type": ["boolean", "null"],
            "description": "ok 재검토 후 확정된 ok 값. 바꿔야 할 경우에만 지정."
          },
          "agreed_with_engine": {
            "type": "boolean",
            "description": "엔진의 primary_decision과 final_decision이 같으면 true"
          },
          "notes": { "type": "string" },
          "_engine_questions": {
            "type": "object",
            "description": "템플릿 생성기가 참고용으로 삽입하는 질문 텍스트. 사람 입력 아님.",
            "additionalProperties": true
          },
          "_engine_short_reason": {
            "type": "string",
            "description": "템플릿 생성기 참고 텍스트. 사람 입력 아님."
          }
        }
      }
    }
  }
}
